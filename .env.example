# Discord Application (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Plex Media Server
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# Server
PORT=3000

# Your public URL — must match the URL mapping in Discord Developer Portal
REDIRECT_URI=https://your-domain.example.com
ALLOWED_ORIGINS=https://your-domain.example.com

# Optional — restrict to specific Discord server(s), comma-separated
# Leave empty to allow all servers
ALLOWED_GUILD_IDS=

# Optional — admin secret for /api/plex/hls/sessions endpoint
ADMIN_SECRET=

# Optional — VPS relay for watch party segment delivery.
# When set, HLS segments route through the VPS instead of this server.
# Also disables P2P (VPS bandwidth makes it unnecessary).
# See docs/vps-relay-setup.md for full setup guide.
# VPS_RELAY_URL=https://theater.yourdomain.com
# VPS_RELAY_KEY=

# Optional — thumbnail cache tuning
# THUMB_CACHE_TTL_MS=604800000
# THUMB_CACHE_MAX_MB=500
